# dtiam Environment Variables
# Copy this file to .env and fill in your values
# Then run: source .env

# OAuth2 Authentication (Recommended)
# Get these from Dynatrace Account Management -> Identity & access management -> OAuth clients
DTIAM_CLIENT_ID=dt0s01.YOUR_CLIENT_ID
DTIAM_CLIENT_SECRET=dt0s01.YOUR_CLIENT_ID.YOUR_SECRET

# Account UUID
# Get this from Dynatrace Account Management -> Account settings
DTIAM_ACCOUNT_UUID=your-account-uuid-here

# Optional: Override context (if using config file)
# DTIAM_CONTEXT=production

# Optional: Default output format (table, json, yaml, csv, wide)
# DTIAM_OUTPUT=table

# Optional: Enable verbose mode
# DTIAM_VERBOSE=true

# Alternative: Bearer Token Authentication (NOT recommended for automation)
# WARNING: Bearer tokens do NOT auto-refresh and will fail when expired
# DTIAM_BEARER_TOKEN=dt0c01.YOUR_BEARER_TOKEN

# Optional: Environment URL for App Engine Registry
# DTIAM_ENVIRONMENT_URL=abc12345.apps.dynatrace.com
